{
  "_comment": "Everything turned on - full registry fields, activity log, backups, strict retention, regenerated-entry splitting in the diff, monorepo-safe component naming, locked locator names. Good starting point for a real project; trim the bits you don't need.",
  "tagger": {
    "rootDir": "src",
    "include": ["**/*.component.html"],
    "ignore": ["**/node_modules/**", "**/*.spec.html"],
    "registryDir": "test-artifacts/testids",
    "attributeName": "data-testid",
    "hashAlgorithm": "sha256",
    "hashLength": 6,
    "collisionStrategy": "auto",
    "idFormat": "{component}__{element}--{key}{disambiguator:--}{hash:-}",
    "componentNaming": "disambiguate",
    "testConfigurationOnly": false,
    "registryRetention": 10,
    "writeActivityLog": true,
    "writeBackups": true,
    "ignoreTags": [],
    "customTagMap": {},
    "registry": {
      "profile": "full"
    }
  },
  "differ": {
    "outputFormats": ["md", "json"],
    "threshold": 0.8,
    "showRegenerated": true
  },
  "locators": {
    "variableFormat": "{component}_{element}_{key}",
    "xpathPrefix": "xpath:",
    "componentNaming": "disambiguate",
    "lockNames": true,
    "mode": "merge"
  }
}
