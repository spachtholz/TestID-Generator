{
  "_comment": "Map your own Angular components to nicer short-names in the generated testids. Without this map, <app-user-menu> becomes element_type 'dom_app-user-menu' — with it, 'menu'. customTagMap also overrides built-in classifications when you want non-default semantics.",
  "tagger": {
    "rootDir": "src",
    "include": ["**/*.component.html"],
    "registryDir": "test-artifacts/testids",
    "testConfigurationOnly": false,
    "customTagMap": {
      "app-user-menu":    { "shortType": "menu",    "longType": "custom_user_menu" },
      "app-notification": { "shortType": "notif",   "longType": "custom_notification" },
      "app-search-box":   { "shortType": "search",  "longType": "custom_search" },
      "app-breadcrumb":   { "shortType": "crumb",   "longType": "custom_breadcrumb" },
      "app-chart":        { "shortType": "chart",   "longType": "custom_chart" },
      "app-data-table":   { "shortType": "table",   "longType": "custom_data_table" },
      "app-modal":        { "shortType": "modal",   "longType": "custom_modal" },
      "app-avatar":       { "shortType": "avatar",  "longType": "custom_avatar" },
      "app-tag":          { "shortType": "tag",     "longType": "custom_tag" }
    },
    "registry": {
      "profile": "standard"
    }
  }
}
