{
  "name": "testid-automation",
  "version": "0.2.1",
  "description": "Build-time Toolchain für Angular: generiert deterministische data-testid-Attribute, versioniert sie, diffed Registry-Stände und erzeugt Robot-Framework-Lokatoren.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "testid": "./dist/cli.js",
    "testid-tagger": "./dist/tagger/cli.js",
    "testid-differ": "./dist/differ/cli.js",
    "testid-gen-locators": "./dist/locators/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@angular/compiler": "^20.0.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.0.1",
    "tinyglobby": "^0.2.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  }
}
